  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>NYCTaxiData</DataSourceName>
        <CommandText>DEFINE VAR __DS0Core = 
	SUMMARIZECOLUMNS(
		ROLLUPADDISSUBTOTAL('green_tripdata_all'[year], "IsGrandTotalRowTotal"),
		"Sumpassenger_count", CALCULATE(SUM('green_tripdata_all'[passenger_count])),
		"Sumtotal_amount", CALCULATE(SUM('green_tripdata_all'[total_amount]))
	)

EVALUATE
	__DS0Core

ORDER BY
	[IsGrandTotalRowTotal] DESC, 'green_tripdata_all'[year]</CommandText>
        <wa:PreviewCommandText>DEFINE
	VAR __DS0Core = 
		SUMMARIZECOLUMNS(
			ROLLUPADDISSUBTOTAL('green_tripdata_all'[year], "IsGrandTotalRowTotal"),
			"Sumpassenger_count", CALCULATE(SUM('green_tripdata_all'[passenger_count])),
			"Sumtotal_amount", CALCULATE(SUM('green_tripdata_all'[total_amount]))
		)

	VAR __DS0BodyLimited = 
		TOPN(500, __DS0Core, [IsGrandTotalRowTotal], 0, 'green_tripdata_all'[year], 1)

EVALUATE
	__DS0BodyLimited

ORDER BY
	[IsGrandTotalRowTotal] DESC, 'green_tripdata_all'[year]</wa:PreviewCommandText>
      </Query>
      <Fields>
        <Field Name="green_5f_tripdata_5f_all_year">
          <DataField>green_tripdata_all[year]</DataField>
          <AggregateIndicatorField xmlns="http://schemas.microsoft.com/sqlserver/reporting/2011/01/reportdefinition">x_5b_IsGrandTotalRowTotal_5d_</AggregateIndicatorField>
        </Field>
        <Field Name="green_5f_tripdata_5f_all_passenger_5f_count">
          <DataField>[Sumpassenger_count]</DataField>
        </Field>
        <Field Name="green_5f_tripdata_5f_all_total_5f_amount">
          <DataField>[Sumtotal_amount]</DataField>
        </Field>
        <Field Name="x_5b_IsGrandTotalRowTotal_5d_">
          <DataField>[IsGrandTotalRowTotal]</DataField>
        </Field>
      </Fields>
      <InterpretSubtotalsAsDetails>False</InterpretSubtotalsAsDetails>
    </DataSet>
