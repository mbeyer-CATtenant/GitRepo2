  <DataSources>
    <DataSource Name="NYCTaxiData">
      <ConnectionProperties>
        <DataProvider>PBIDATASET</DataProvider>
        <ConnectString>Data Source=pbiazure://api.powerbi.com/;Identity Provider="https://login.microsoftonline.com/common, https://analysis.windows.net/powerbi/api, f0b72488-7082-488a-a7e8-eada97bd842d";Initial Catalog=sobe_wowvirtualserver-3229ce72-909a-4e6a-a002-e2a94e0577e9;Integrated Security=ClaimsToken</ConnectString>
      </ConnectionProperties>
